# =============================================================================
# Elitesphere Consultancy — environment variables
# Copy this file to `.env` (gitignored) and fill in real values for production.
# =============================================================================

# Supabase project URL (e.g. https://abcdefghij.supabase.co)
# Used by the contact form to persist inquiries to a `inquiries` table.
VITE_SUPABASE_URL=

# Supabase anon public key (safe to expose in the browser).
# Get it from Supabase Dashboard → Project Settings → API.
VITE_SUPABASE_ANON_KEY=

# Optional: receive an email whenever a new inquiry lands.
# Either set up a Supabase Database Webhook to point at your email service
# (Resend, SendGrid, Postmark), or wire a Supabase Edge Function.
# Leave blank if you only want to read inquiries inside Supabase Studio.